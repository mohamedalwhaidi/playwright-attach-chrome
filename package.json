{
  "name": "playwright-attach-chrome",
  "version": "0.2.0",
  "description": "Attach Playwright to a real Chrome session — capture & filter network traffic from a logged-in window. Export HAR. CLI + MCP server.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "playwright-attach-chrome": "./dist/cli.js",
    "pac": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "playwright",
    "chrome",
    "cdp",
    "network-capture",
    "har",
    "devtools",
    "reverse-engineering",
    "api-inspection",
    "mcp",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.1.0",
    "playwright-core": "^1.50.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
